@model LoginViewModel

<div class="row justify-content-center loginForm">
    <div class="col-md-8">
        <h2>Please log in before placing an order.</h2>
        <form asp-controller="Account" asp-action="Login" method="post" class="needs-validation" novalidate>
            <h4>Enter your details below</h4>
            <hr />
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="mb-3 row">
                <label asp-for="UserName" class="col-sm-2 col-form-label"></label>
                <div class="col-sm-10">
                    <input asp-for="UserName" class="form-control" />
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="Password" class="col-sm-2 col-form-label"></label>
                <div class="col-sm-10">
                    <input asp-for="Password" type="password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-sm-10 offset-sm-2 text-end">
                    <button type="submit" class="btn btn-success">Log in</button>
                </div>
            </div>
        </form>
    </div>
</div>
